# Copy this file to local.properties and fill in the values for your machine.
# local.properties is gitignored — never commit it.

# Path to your JDK 21 installation.
# Required: the Android build does not work with JDK 17 or JDK 25+.
#
# macOS (Homebrew):   /opt/homebrew/opt/openjdk@21
# Ubuntu:             /usr/lib/jvm/java-21-openjdk-amd64
# Windows:            C\:\\Program Files\\Eclipse Adoptium\\jdk-21...
java.home=/usr/lib/jvm/java-21-openjdk-amd64

# Path to your Android SDK (set automatically by Android Studio, otherwise set manually)
# sdk.dir=/home/<you>/Android/Sdk
